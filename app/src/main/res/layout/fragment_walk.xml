<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:padding="20dp">

    <!-- Destination Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDestination"
        style="@style/WAY.Card.Outlined"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_location"
                app:tint="@color/way_primary"
                android:contentDescription="@string/cd_destination" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/walk_select_destination"
                    style="@style/WAY.Text.LabelLarge" />

                <TextView
                    android:id="@+id/tvDestination"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/walk_tap_to_select"
                    style="@style/WAY.Text.BodyLarge"
                    android:textColor="@color/way_primary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="@color/way_on_surface_variant"
                android:contentDescription="@string/cd_search_destination" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Walk stats row -->
    <LinearLayout
        android:id="@+id/walkInfoContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardDestination"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Distance card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/WAY.Card.Filled"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/way_card_tint_blue">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_trending_up"
                    app:tint="@color/way_tertiary"
                    android:contentDescription="@string/cd_distance" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/walk_distance_placeholder"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/way_on_surface"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/walk_distance_label"
                    style="@style/WAY.Text.LabelSmall" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Time card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/WAY.Card.Filled"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:cardBackgroundColor="@color/way_card_tint_green">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_timer"
                    app:tint="@color/way_safe_green"
                    android:contentDescription="@string/cd_time" />

                <TextView
                    android:id="@+id/tvElapsedTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/walk_time_placeholder"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/way_on_surface"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/walk_time_label"
                    style="@style/WAY.Text.LabelSmall" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Walk state chip -->
    <com.google.android.material.chip.Chip
        android:id="@+id/chipWalkState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/walk_state_idle"
        app:chipBackgroundColor="@color/way_primary_container"
        android:textColor="@color/way_on_primary_container"
        app:chipIcon="@drawable/ic_check"
        app:chipIconTint="@color/way_on_primary_container"
        app:chipMinHeight="36dp"
        android:textSize="13sp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/walkInfoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- SOS Button — big red circle -->
    <View
        android:id="@+id/sosOuterRing"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/bg_sos_button"
        android:alpha="0.2"
        app:layout_constraintTop_toBottomOf="@id/chipWalkState"
        app:layout_constraintBottom_toTopOf="@id/btnEndWalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSOS"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:text="@string/walk_btn_sos"
        android:textSize="24sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/white"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="60dp"
        app:backgroundTint="@color/way_emergency_red"
        app:layout_constraintTop_toBottomOf="@id/chipWalkState"
        app:layout_constraintBottom_toTopOf="@id/btnEndWalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- End Walk Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEndWalk"
        style="@style/WAY.Button.Outlined"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/walk_btn_end"
        android:layout_marginBottom="8dp"
        app:strokeColor="@color/way_outline"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

