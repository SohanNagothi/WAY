<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Where are you heading?"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/way_on_surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Enter your destination so we can keep you safe"
        android:textSize="14sp"
        android:textColor="@color/way_on_surface_variant"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Destination input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilDestination"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:boxCornerRadiusTopStart="14dp"
        app:boxCornerRadiusTopEnd="14dp"
        app:boxCornerRadiusBottomStart="14dp"
        app:boxCornerRadiusBottomEnd="14dp"
        app:startIconDrawable="@drawable/ic_location"
        app:startIconTint="@color/way_primary"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDestination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter destination name"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionDone" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUseGps"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Use my GPS for nearby places"
        app:icon="@drawable/ic_location"
        app:iconTint="@color/way_primary"
        app:layout_constraintTop_toBottomOf="@id/tilDestination"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvGpsStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="GPS not loaded yet"
        android:textColor="@color/way_on_surface_variant"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/btnUseGps"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Places autocomplete suggestions (overlays saved locations) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSuggestions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvGpsStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlacesSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp"
            android:nestedScrollingEnabled="true"
            android:visibility="gone"
            android:background="@color/way_surface_container" />
    </androidx.cardview.widget.CardView>

    <!-- Saved locations label -->
    <TextView
        android:id="@+id/tvSavedLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Saved Locations"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/way_on_surface"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvGpsStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Saved locations list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLocations"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/tvSavedLabel"
        app:layout_constraintBottom_toTopOf="@id/btnStartWalk"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty state for saved locations -->
    <TextView
        android:id="@+id/tvNoSaved"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No saved locations yet.\nYou can add them in Settings."
        android:textSize="14sp"
        android:textColor="@color/way_on_surface_variant"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/tvSavedLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Start Walk button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartWalk"
        style="@style/WAY.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="🚶 Start Walk"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

