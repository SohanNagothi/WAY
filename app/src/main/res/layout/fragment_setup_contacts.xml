<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_contacts"
            app:tint="@color/way_primary"
            android:contentDescription="@string/setup_step_contacts" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_step_contacts"
            style="@style/WAY.Text.TitleLarge"
            android:gravity="center"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_contacts_description"
            style="@style/WAY.Text.BodyMedium"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <!-- Contact 1 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilContactName1"
            style="@style/WAY.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/ic_person"
            app:startIconTint="@color/way_on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etContactName1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/contact_name_hint"
                android:inputType="textPersonName"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilContactPhone1"
            style="@style/WAY.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:startIconDrawable="@drawable/ic_phone"
            app:startIconTint="@color/way_on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etContactPhone1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/contact_phone_hint"
                android:inputType="phone"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/way_divider"
            android:layout_marginVertical="16dp" />

        <!-- Contact 2 (optional) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilContactName2"
            style="@style/WAY.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/ic_person"
            app:startIconTint="@color/way_on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etContactName2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/setup_contact_2_hint"
                android:inputType="textPersonName"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilContactPhone2"
            style="@style/WAY.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:startIconDrawable="@drawable/ic_phone"
            app:startIconTint="@color/way_on_surface_variant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etContactPhone2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/contact_phone_hint"
                android:inputType="phone"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

